- id: front_driveway_motion_lights_on
  alias: "Front Driveway - Lights On When Motion (Dark)"
  description: "Turn on driveway light on motion at night, off after 5min no motion or 10min hard cap"
  trigger:
    - platform: state
      entity_id: binary_sensor.front_driveway_door_motion
      to: "on"
  condition:
    - condition: state
      entity_id: binary_sensor.front_driveway_door_is_dark
      state: "on"
  action:
    - service: light.turn_on
      target:
        entity_id: light.front_driveway
      data:
        brightness_pct: 100
    - wait_for_trigger:
        - platform: state
          entity_id: binary_sensor.front_driveway_door_motion
          to: "off"
          for:
            minutes: 5
      timeout:
        minutes: 10
      continue_on_timeout: true
    - service: light.turn_off
      target:
        entity_id: light.front_driveway
      data:
        transition: 5
  mode: restart

- id: front_driveway_auto_off
  alias: "Front Driveway - Auto Off After No Motion"
  description: "Safety net: turn off driveway lights 5 minutes after no motion"
  trigger:
    - platform: state
      entity_id: binary_sensor.front_driveway_door_motion
      to: "off"
      for:
        minutes: 5
  condition:
    - condition: state
      entity_id: light.front_driveway
      state: "on"
  action:
    - service: light.turn_off
      target:
        entity_id: light.front_driveway
      data:
        transition: 5
  mode: restart

- id: garage_lights_auto_off
  alias: "Garage - Auto Off After No Motion"
  description: "Turn off garage lights 5 minutes after no motion"
  trigger:
    - platform: state
      entity_id: binary_sensor.garage_motion_combined
      to: "off"
      for:
        minutes: 5
  condition:
    - condition: state
      entity_id: light.garage
      state: "on"
  action:
    - service: light.turn_off
      target:
        entity_id: light.garage
      data:
        transition: 5
  mode: restart

- id: garage_walkin_door_lights_on
  alias: "Garage - Lights On When Walk-in Door Opens"
  description: "Turn on garage lights when walk-in door opens"
  trigger:
    - platform: state
      entity_id: binary_sensor.garage_walk_in_door
      to: "on"
  action:
    - service: light.turn_on
      target:
        entity_id: light.garage
      data:
        brightness_pct: 100
  mode: restart
